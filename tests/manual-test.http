### Health check
GET http://127.0.0.1:8000/health

### Register Alice
POST http://127.0.0.1:8000/auth/register
Content-Type: application/json

{
  "username": "alice",
  "password": "alice123",
  "tenant_id": "tenant-a",
  "role": "user"
}

### Login Alice
POST http://127.0.0.1:8000/auth/login
Content-Type: application/json

{
  "username": "alice",
  "password": "alice123"
}

### Create Alice document
POST http://127.0.0.1:8000/documents
Content-Type: application/json
Authorization: Bearer {{alice_token}}

{
  "title": "Alice private document",
  "content": "This is Alice private RAG document."
}

### Register Bob
POST http://127.0.0.1:8000/auth/register
Content-Type: application/json

{
  "username": "bob",
  "password": "bob12345",
  "tenant_id": "tenant-b",
  "role": "user"
}

### Login Bob
POST http://127.0.0.1:8000/auth/login
Content-Type: application/json

{
  "username": "bob",
  "password": "bob12345"
}

### Bob attempts to read Alice document
GET http://127.0.0.1:8000/documents/1
Authorization: Bearer {{bob_token}}

### Login default admin
POST http://127.0.0.1:8000/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin123"
}

### Admin lists all documents
GET http://127.0.0.1:8000/admin/documents
Authorization: Bearer {{admin_token}}

### Alice creates a RAG-sensitive document
POST http://127.0.0.1:8000/documents
Content-Type: application/json
Authorization: Bearer {{alice_token}}

{
  "title": "Alice secret plan",
  "content": "Project phoenix secret: Alice owns this private RAG document."
}

### Alice queries safe RAG and can find her own document
POST http://127.0.0.1:8000/rag/query
Content-Type: application/json
Authorization: Bearer {{alice_token}}

{
  "query": "phoenix secret",
  "max_results": 5
}

### Bob queries safe RAG and should not find Alice document
POST http://127.0.0.1:8000/rag/query
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "query": "phoenix secret",
  "max_results": 5
}

### Bob queries intentionally vulnerable RAG and can find Alice document
POST http://127.0.0.1:8000/lab/vulnerable-rag/query
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "query": "phoenix secret",
  "max_results": 5
}

### Alice creates an order
POST http://127.0.0.1:8000/orders
Content-Type: application/json
Authorization: Bearer {{alice_token}}

{
  "item_name": "Security Book",
  "shipping_address": "Alice Old Address"
}

### Alice lists her orders
GET http://127.0.0.1:8000/orders
Authorization: Bearer {{alice_token}}

### Bob safely queries Alice order and should receive 403
POST http://127.0.0.1:8000/agent/tools/order-query
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "order_id": 1
}

### Bob uses intentionally vulnerable order query and can read Alice order
POST http://127.0.0.1:8000/lab/vulnerable-agent/order-query
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "order_id": 1
}

### Bob safely updates Alice order address and should receive 403
POST http://127.0.0.1:8000/agent/tools/address-update
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "order_id": 1,
  "new_address": "Bob Attack Address"
}

### Bob uses intentionally vulnerable address update and can modify Alice order
POST http://127.0.0.1:8000/lab/vulnerable-agent/address-update
Content-Type: application/json
Authorization: Bearer {{bob_token}}

{
  "order_id": 1,
  "new_address": "Bob Attack Address"
}

### Alice sees that her order address was modified through the vulnerable tool
GET http://127.0.0.1:8000/orders
Authorization: Bearer {{alice_token}}
